# ============================================================
# ШАБЛОН КОНФИГУРАЦИИ СЕРВИСА СИНХРОНИЗАЦИИ
# ============================================================
# Инструкция:
# 1. Скопируйте этот файл и переименуйте в .env
# 2. Заполните значения своими данными
# 3. НЕ коммитьте файл .env в Git (он добавлен в .gitignore)
# ============================================================

# Путь к локальной папке для синхронизации
# Используйте абсолютный путь
# Примеры:
#   Windows: C:/Users/Станислав/Documents/sync_folder
#   Linux/macOS: /home/username/sync_folder
LOCAL_FOLDER=C:/путь/к/вашей/папке

# Имя папки на Яндекс Диске (создастся автоматически, если её нет)
# Эта папка будет корневой для синхронизации
YANDEX_FOLDER=skillbox_sync

# OAuth токен Яндекс Диска
# Получить можно на: https://yandex.ru/dev/disk/poligon/
# 1. Войдите в аккаунт Яндекс
# 2. Нажмите "Получить токен"
# 3. Скопируйте токен и вставьте сюда
YANDEX_TOKEN=your_token_here

# Интервал синхронизации в секундах
# Рекомендуемые значения: 10-60 секунд
# Минимальное значение: 1
SYNC_PERIOD=10

# Имя файла для логов
# Логи будут сохраняться в корне проекта
LOG_FILE=sync.log